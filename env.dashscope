# DashScope (Alibaba Cloud) — copy to .env and set your keys
# Get key: https://dashscope.console.aliyun.com/

# -----------------------------------------------------------------------------
# Core / runtime
# -----------------------------------------------------------------------------
NOESIUM_LLM_PROVIDER=openai
NOESIUM_EMBEDDING_DIMS=1536

# -----------------------------------------------------------------------------
# OpenAI (DashScope compatible-mode); set OPENAI_BASE_URL for DashScope
# -----------------------------------------------------------------------------
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your_dashscope_api_key_here
OPENAI_CHAT_MODEL=qwen3.5-flash
OPENAI_VISION_MODEL=qwen3.5-flash
OPENAI_EMBED_MODEL=text-embedding-v4

# -----------------------------------------------------------------------------
# Web search / toolkits
# -----------------------------------------------------------------------------
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# Browser Use subagent (BU)
# -----------------------------------------------------------------------------
BROWSER_USE_HEADLESS=true
