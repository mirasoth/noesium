# Ollama (local LLMs) — copy to .env
# Install: https://ollama.ai/ — then: ollama pull <model>

NOE_LLM_PROVIDER=ollama
# Chat / vision / embed (must be pulled locally)
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
NOE_EMBEDDING_DIMS=768

# Tavily web search (optional)
TAVILY_API_KEY=
