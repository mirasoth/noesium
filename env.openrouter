# OpenRouter — copy to .env and set your keys
# Get key: https://openrouter.ai/keys

NOE_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Chat / vision / embed model IDs (e.g. google/gemini-2.5-flash)
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_EMBED_MODEL=text-embedding-3-small
NOE_EMBEDDING_DIMS=1536

# Tavily web search (optional)
TAVILY_API_KEY=
