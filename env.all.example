# Noesium env template — copy to .env and set keys. Do not commit .env.
# Scanned from codebase; only set vars you use.

# -----------------------------------------------------------------------------
# Core / runtime
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
NOE_LLM_PROVIDER=openai
NOE_AGENT_CONFIG=
NOE_EMBEDDING_DIMS=768
NOE_FILE_LOG_LEVEL=
NOE_LLM_DEBUG=false
NOE_ENABLE_TRACING=false
NOE_DEMO_MODE=true

# -----------------------------------------------------------------------------
# OpenAI (chat / vision / embed); also used for DashScope when OPENAI_BASE_URL set
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_VISION_MODEL=gpt-4-vision-preview
OPENAI_EMBED_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# LiteLLM (multi-provider)
# -----------------------------------------------------------------------------
LITELLM_CHAT_MODEL=gpt-3.5-turbo
LITELLM_VISION_MODEL=gpt-4-vision-preview
LITELLM_EMBED_MODEL=text-embedding-ada-002

# -----------------------------------------------------------------------------
# Ollama (local)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# -----------------------------------------------------------------------------
# LlamaCPP (local GGUF)
# -----------------------------------------------------------------------------
LLAMACPP_MODEL_PATH=
LLAMACPP_CHAT_MODEL=
LLAMACPP_VISION_MODEL=
LLAMACPP_EMBED_MODEL=
LLAMACPP_N_CTX=2048
LLAMACPP_N_GPU_LAYERS=0

# -----------------------------------------------------------------------------
# OpenRouter
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3-haiku
OPENROUTER_VISION_MODEL=anthropic/claude-3-haiku
OPENROUTER_EMBED_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Vector store
# -----------------------------------------------------------------------------
NOE_VECTOR_STORE_PROVIDER=weaviate
# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_AUTH_SECRET=
# PgVector (POSTGRES_* or tests: PGVECTOR_*)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vectordb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
USE_HNSW=true
USE_DISKANN=false

# -----------------------------------------------------------------------------
# Web search / toolkits
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=
GOOGLE_AI_SEARCH_API_KEY=
GOOGLE_AI_SEARCH_ENGINE_ID=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OPIK tracing (optional)
# -----------------------------------------------------------------------------
NOE_OPIK_TRACING=false
OPIK_USE_LOCAL=true
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=noesium-llm
OPIK_TRACING=true
OPIK_LOCAL_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Browser Use subagent (BU)
# -----------------------------------------------------------------------------
BROWSER_USE_LOGGING_LEVEL=info
BROWSER_USE_CONFIG_DIR=
BROWSER_USE_SETUP_LOGGING=true
BROWSER_USE_API_KEY=
BROWSER_USE_SCREENSHOT_FILE=
BROWSER_USE_DISABLE_EXTENSIONS=
BROWSER_USE_VERBOSE_OBSERVABILITY=false
XDG_CACHE_HOME=~/.cache
XDG_CONFIG_HOME=~/.config
PLAYWRIGHT_BROWSERS_PATH=
# LLM keys used by BU (if not set, inherits from above)
# ANTHROPIC_API_KEY= GOOGLE_API_KEY= DEEPSEEK_API_KEY= GROK_API_KEY= NOVITA_API_KEY=
# AZURE_OPENAI_ENDPOINT= AZURE_OPENAI_KEY=
SKIP_LLM_API_KEY_VERIFICATION=false
DEFAULT_LLM=
IN_DOCKER=false
IS_IN_EVALS=false
WIN_FONT_DIR=C:\Windows\Fonts
LMNR_LOGGING_LEVEL=
# Optional: TIMEOUT_<EventName> (float seconds) e.g. TIMEOUT_NavigateToUrlEvent=15.0

# -----------------------------------------------------------------------------
# Other toolkits (set only if using)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GMAIL_ACCESS_TOKEN=
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_APP_KEY=
ALIYUN_REGION_ID=cn-shanghai
# LiteLLM provider keys
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# NoeCoder backend (coder-backend)
# -----------------------------------------------------------------------------
# NOECODER_HOST=127.0.0.1
# NOECODER_PORT=8000
# NOECODER_DEBUG=false
# NOECODER_DATA_ROOT=~/.noecoder
# NOECODER_LLM_PROVIDER=openai
# NOECODER_LLM_MODEL=
# NOECODER_MAX_ITERATIONS=25
# NOECODER_REFLECTION_INTERVAL=3
# NOECODER_MAX_CONCURRENT_TASKS=1
# NOECODER_TASK_TIMEOUT_SECONDS=600
# NOECODER_DEFAULT_BRANCH=main
# NOECODER_AUTO_COMMIT=true
# NOECODER_COMMIT_MESSAGE_PREFIX=[NoeCoder]
# NOECODER_THEME=dark
# NOECODER_SHOW_THINKING=true
# NOECODER_SHOW_TOOL_DETAILS=true

# -----------------------------------------------------------------------------
# Tests (pytest / integration)
# -----------------------------------------------------------------------------
# INTEGRATION_TESTS=false
# SLOW_TESTS=false
# TEST_DEBUG=false
